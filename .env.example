# Production environment variables for AWS Lightsail
# Copy this to .env and fill in your values:
#   cp .env.example .env

# Comma-separated list of allowed frontend origins
# Set to your Cloudflare Pages domain (and custom domain if you have one)
# Example: https://cv-showcase.pages.dev,https://cv.yourdomain.com
ALLOWED_ORIGINS=https://your-project.pages.dev
